{
  "name": "@gofreego/tsutils",
  "version": "0.1.15",
  "description": "A comprehensive React + TypeScript library with common utilities, components, theme system, and HTTP client",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./dist/index.css": "./dist/index.css"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "example:install": "cd example && npm install",
    "example:dev": "cd example && npm run dev",
    "example:build": "cd example && npm run build",
    "example": "npm run build && npm run example:install && npm run example:dev"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gofreego/tsutils.git"
  },
  "keywords": [
    "react",
    "typescript",
    "components",
    "theme",
    "http-client",
    "utilities",
    "ui",
    "library"
  ],
  "author": "gofreego",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/gofreego/tsutils/issues"
  },
  "homepage": "https://github.com/gofreego/tsutils#readme",
  "devDependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^6.5.0",
    "@mui/material": "^6.5.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react-router-dom": "^7.13.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@emotion/react": "^11.0.0",
    "@emotion/styled": "^11.0.0",
    "@mui/icons-material": "^5.0.0 || ^6.0.0 || ^7.0.0",
    "@mui/material": "^5.0.0 || ^6.0.0 || ^7.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "react-router-dom": "^6.0.0 || ^7.0.0"
  },
  "peerDependenciesMeta": {
    "@emotion/react": {
      "optional": true
    },
    "@emotion/styled": {
      "optional": true
    },
    "@mui/material": {
      "optional": true
    },
    "@mui/icons-material": {
      "optional": true
    },
    "react-router-dom": {
      "optional": true
    }
  },
  "dependencies": {
    "katex": "^0.16.44",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "shiki": "^3.23.0"
  }
}
